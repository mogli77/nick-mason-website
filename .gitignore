# OS files
.DS_Store

# RAW camera files
*.ARW
*.arw

# Source design files (keep in assets/ but don't deploy)
*.ai
*.eps
*.psd
*.xmp

# SVG source pages (keep only the optimized nick-mason-logo.svg)
assets/logo/brand_page*.svg
assets/logo/brand_identity*.svg
assets/logo/preview_page*.png

# Temp/placeholder content
images/temp/

# Full-res originals and SELECTS (only commit web-optimized versions)
# Project root-level jpegs are full-res originals — only web/ subfolder is committed
images/projects/*/*.jpg
images/projects/*/*.JPG
images/projects/*/*.jpeg
images/projects/*/SELECTS/
images/crew/*.jpg
images/crew/*.JPG
images/crew/*.jpeg
images/crew/SELECTS/
images/construction/*.jpg
images/construction/*.JPG
images/construction/*.jpeg
images/construction/*.ARW

# Local Netlify folder
.netlify

# Playwright CLI output
.playwright-cli/
.playwright-mcp/

# Claude Code local config (dev preview server config, etc.)
.claude/

# Local backup files
*.bak
